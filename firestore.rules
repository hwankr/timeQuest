rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 인증된 사용자 본인의 데이터 트리만 읽기/쓰기 허용
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // 그 외 모든 경로 접근 거부
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
